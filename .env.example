# Copy to .env and fill in.

# Secret used to sign session cookies (JWT). Generate a long random string:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET=change-me-to-a-long-random-string

# SQLite database location.
# Dev (running `npm run dev` on the host). SQLite paths are relative to the
# prisma/ folder, so this resolves to prisma/dev.db:
DATABASE_URL=file:./dev.db
# Docker uses file:/data/app.db (set in docker-compose.yml).

# Internal Suwayomi-Server GraphQL engine.
# Dev against the dockerized Suwayomi (port published to localhost):
SUWAYOMI_URL=http://localhost:4567
# Docker uses http://suwayomi:4567 (set in docker-compose.yml).

# FlareSolverr proxy for Cloudflare-protected metadata sources (comick).
# Dev against the published localhost port; Docker uses http://flaresolverr:8191.
FLARESOLVERR_URL=http://localhost:8191

# ---- Docker deploy (docker compose up -d) ----
# Host port published for the web container; the tunnel routes to it.
# Pick any free port (avoids clashing with other local servers).
WEB_PORT=3000

# Cloudflare Tunnel connector token. Zero Trust dashboard:
# Networks > Tunnels > Create tunnel > copy the token from the install command.
# The tunnel publishes the web app to reader.horizonfps.space over HTTPS.
CF_TUNNEL_TOKEN=change-me
# COOKIE_SECURE defaults to "true" in docker-compose (HTTPS via Cloudflare) and
# uploads + the SQLite db persist on the ./data volume. No extra vars needed.
