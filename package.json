{
  "name": "horizonreader",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "user": "node --env-file-if-exists=.env --experimental-strip-types scripts/user.ts",
    "fix-titles": "node --env-file-if-exists=.env --experimental-strip-types scripts/fix-titles.ts",
    "fix-sources": "node --env-file-if-exists=.env --experimental-strip-types scripts/fix-sources.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "bcryptjs": "^2.4.3",
    "embla-carousel-react": "^8.5.2",
    "exceljs": "^4.4.0",
    "fastest-levenshtein": "^1.0.16",
    "jose": "^5.9.6",
    "lucide-react": "^0.469.0",
    "next": "^15.1.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "swr": "^2.3.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^6.2.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  }
}
